# ─────────────────────────────────────────
# Florería Karel — Environment Variables
# Copy this to .env and fill in your values
# ─────────────────────────────────────────

# PostgreSQL — provided by Railway/Render automatically
DATABASE_URL="postgresql://user:password@host:5432/karel_db"

# JWT secret — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="replace_with_a_long_random_string"
JWT_EXPIRES_IN="8h"

# Admin PIN (hashed at startup — change this to your real PIN)
ADMIN_PIN="1234"

# Server
PORT=3000
NODE_ENV="development"

# CORS — set to your frontend domain in production
CORS_ORIGIN="http://localhost:5500"

# Stripe (website payments)
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# File uploads (use Cloudinary or similar in production)
UPLOAD_DIR="./uploads"
MAX_FILE_SIZE_MB=5
